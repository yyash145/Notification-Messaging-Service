model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String?
  isActive       Boolean?      @default(true)
  role           Role?         @default(USER)
  refreshToken   String?
  createdAt      DateTime      @default(now())
  organizationId String?
  auditLogs      AuditLog[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  templates      template[]
  messages       Message[]
}
